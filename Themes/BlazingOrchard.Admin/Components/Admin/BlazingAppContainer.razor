@using BlazingOrchard.Admin.DisplayManagement
@using BlazingOrchard.Admin.Options
@using Radzen
@using Radzen.Blazor
@implements IDisposable
@inject DisplayManager DisplayManager
@inject BlazingRoutingOptions Routing
@inject NavigationManager Navigation

@if (!DisplayManager.IsInitialized)
{
    <RadzenStack Gap="1rem" Style="padding: 2rem;">
        <RadzenText Text="Loading..." />
    </RadzenStack>
}
else if (DisplayManager.IsAuthenticated)
{
    <CascadingValue Value="DisplayManager">
        @ChildContent
    </CascadingValue>
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    protected override async Task OnInitializedAsync()
    {
        DisplayManager.Changed += StateHasChanged;
        await DisplayManager.EnsureInitializedAsync();
        EnsureAuthenticated();
    }

    public void Dispose()
    {
        DisplayManager.Changed -= StateHasChanged;
    }

    private void EnsureAuthenticated()
    {
        if (!DisplayManager.IsAuthenticated)
        {
            Navigation.NavigateTo(Routing.LoginPath);
        }
    }
}
