@using BlazingOrchard.Admin.DisplayManagement
@using Radzen
@using Radzen.Blazor

<RadzenSidebar class="admin-menu-sidebar">
    <RadzenStack Gap="0.75rem" class="admin-menu-sidebar__content">
        <RadzenText TextStyle="TextStyle.H6" Text="Admin" class="admin-menu-sidebar__title" />

        @if (DisplayManager is null)
        {
            <RadzenText TextStyle="TextStyle.Body2" Text="Display manager is unavailable." />
        }
        else if (Menu is null)
        {
            <RadzenText TextStyle="TextStyle.Body2" Text="Loading admin menu..." />
        }
        else
        {
            <RadzenPanelMenu class="admin-menu-sidebar__menu">
                <AdminMenuPanelItems Items="Menu.Items" />
            </RadzenPanelMenu>

            @if (Menu.Items.Length == 0)
            {
                <RadzenText TextStyle="TextStyle.Body2" Text="No admin menu items returned." />
            }
        }
    </RadzenStack>
</RadzenSidebar>

@code {
    [CascadingParameter]
    public DisplayManager? DisplayManager { get; set; }

    private DisplayMenu? Menu => DisplayManager?.AdminMenu;
}
