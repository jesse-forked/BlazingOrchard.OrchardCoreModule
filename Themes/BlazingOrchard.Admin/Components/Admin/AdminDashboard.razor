@using BlazingOrchard.Admin.Api
@using BlazingOrchard.Admin.DisplayManagement
@using BlazingOrchard.Admin.Options
@using Radzen
@using Radzen.Blazor
@inject BlazingRoutingOptions Routing
@inject NavigationManager Navigation

<div class="admin-dashboard">
    <AdminMenuSidebar />

    <main class="admin-dashboard__main">
        <RadzenStack Gap="1rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <ShapeView Shape="@AdminStatusShape" />
                <RadzenButton Text="Logout" Click="LogoutAsync" Disabled="@(DisplayManager?.IsBusy == true)" />
            </RadzenStack>

            <RadzenTabs>
                <Tabs>
            <RadzenTabsItem Text="App">
                @if (DisplayManager?.Manifest is null)
                {
                    <RadzenText Text="Loading app manifest..." />
                }
                else
                {
                    <RadzenStack Gap="0.75rem">
                        <RadzenText TextStyle="TextStyle.H6" Text="@DisplayManager.Manifest.Site.SiteName" />
                        <RadzenText Text="@($"Tenant: {DisplayManager.Manifest.Tenant.Name} · State: {DisplayManager.Manifest.Tenant.State} · Admin: {DisplayManager.Manifest.Admin.BasePath}")" />
                        <RadzenText TextStyle="TextStyle.Caption" Text="@($"Feature hash: {DisplayManager.Manifest.FeatureHash}")" />
                        <RadzenText Text="@($"Enabled features: {DisplayManager.Manifest.Features.Length}")" />
                        <RadzenText Text="@($"Roles: {DisplayManager.Roles.Length}")" />
                    </RadzenStack>
                }
            </RadzenTabsItem>

            <RadzenTabsItem Text="Site">
                @if (Site is null)
                {
                    <RadzenText Text="Loading site settings..." />
                }
                else
                {
                    <RadzenStack Gap="1rem" Style="max-width: 48rem;">
                        <RadzenTextBox @bind-Value="Site.SiteName" Placeholder="Site name" />
                        <RadzenTextBox @bind-Value="Site.PageTitleFormat" Placeholder="Page title format" />
                        <RadzenTextBox @bind-Value="Site.BaseUrl" Placeholder="Base URL" />
                        <RadzenTextBox @bind-Value="Site.TimeZoneId" Placeholder="Time zone ID" />
                        <RadzenTextBox @bind-Value="Site.Calendar" Placeholder="Calendar" />
                        <RadzenNumeric @bind-Value="Site.PageSize" Placeholder="Page size" />
                        <RadzenNumeric @bind-Value="Site.MaxPageSize" Placeholder="Max page size" />
                        <RadzenNumeric @bind-Value="Site.MaxPagedCount" Placeholder="Max paged count" />
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenButton Text="Save site settings" Click="SaveSiteAsync" Disabled="@IsLoading" />
                            <RadzenButton Text="Refresh" ButtonStyle="ButtonStyle.Light" Click="LoadAsync" Disabled="@IsLoading" />
                        </RadzenStack>
                        @if (!string.IsNullOrWhiteSpace(Status))
                        {
                            <RadzenText TextStyle="TextStyle.Caption" Text="@Status" />
                        }
                    </RadzenStack>
                }
            </RadzenTabsItem>

            <RadzenTabsItem Text="Content">
                <RadzenStack Gap="1rem">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                        <RadzenTextBox @bind-Value="ContentHandle" Placeholder="alias:main-menu" Style="min-width: 18rem;" />
                        <RadzenButton Text="Load by handle" Click="LoadContentItemAsync" Disabled="@IsLoading" />
                    </RadzenStack>

                    @if (DisplayManager?.CurrentContentItem is not null)
                    {
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.H6" Text="@DisplayManager.CurrentContentItem.DisplayText" />
                            <RadzenText Text="@($"{DisplayManager.CurrentContentItem.ContentType} · {DisplayManager.CurrentContentItem.ContentItemId}")" />
                        </RadzenCard>
                    }

                    <RadzenText TextStyle="TextStyle.H6" Text="Content types" />
                    @if (DisplayManager?.ContentTypes.Length is null or 0)
                    {
                        <RadzenText Text="No content types returned." />
                    }
                    else
                    {
                        <ul>
                            @foreach (var contentType in DisplayManager.ContentTypes)
                            {
                                <li>@contentType.DisplayName (@contentType.Name) · @contentType.Parts.Length parts</li>
                            }
                        </ul>
                    }
                </RadzenStack>
            </RadzenTabsItem>
                </Tabs>
            </RadzenTabs>
        </RadzenStack>
    </main>
</div>

@code {
    [CascadingParameter]
    public DisplayManager? DisplayManager { get; set; }

    private EditableSiteSettings? Site { get; set; }
    private string ContentHandle { get; set; } = "alias:main-menu";
    private bool IsLoading { get; set; }
    private string? Status { get; set; }

    private Shape? AdminStatusShape => DisplayManager?.NewShape(
        nameof(AdminStatus),
        shape => shape.Properties[nameof(AdminStatus.UserName)] = DisplayManager.User.UserName);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        if (DisplayManager is null)
        {
            return;
        }

        IsLoading = true;
        Status = null;

        if (DisplayManager.Manifest is null)
        {
            await DisplayManager.RefreshAdminStateAsync();
        }

        BindEditableSite();

        IsLoading = false;
    }

    private async Task LoadContentItemAsync()
    {
        if (DisplayManager is null || string.IsNullOrWhiteSpace(ContentHandle))
        {
            return;
        }

        IsLoading = true;
        await DisplayManager.LoadContentItemByHandleAsync(ContentHandle.Trim());
        IsLoading = false;
    }

    private async Task SaveSiteAsync()
    {
        if (DisplayManager is null || Site is null)
        {
            return;
        }

        IsLoading = true;
        Status = null;

        var saved = await DisplayManager.UpdateSiteAsync(Site.ToUpdate());
        if (saved is null)
        {
            Status = DisplayManager.ErrorMessage ?? "Unable to save site settings.";
        }
        else
        {
            Site = EditableSiteSettings.From(saved);
            Status = "Site settings saved.";
        }

        IsLoading = false;
    }

    private async Task LogoutAsync()
    {
        if (DisplayManager is not null)
        {
            await DisplayManager.LogoutAsync();
            Navigation.NavigateTo(Routing.LoginPath);
        }
    }

    private void BindEditableSite()
    {
        if (DisplayManager?.Site is not null)
        {
            Site = EditableSiteSettings.From(DisplayManager.Site);
        }
    }

    private sealed class EditableSiteSettings
    {
        public string SiteName { get; set; } = string.Empty;
        public string PageTitleFormat { get; set; } = string.Empty;
        public string BaseUrl { get; set; } = string.Empty;
        public string TimeZoneId { get; set; } = string.Empty;
        public string Calendar { get; set; } = string.Empty;
        public int PageSize { get; set; }
        public int MaxPageSize { get; set; }
        public int MaxPagedCount { get; set; }

        public static EditableSiteSettings From(SiteSettings settings) => new()
        {
            SiteName = settings.SiteName,
            PageTitleFormat = settings.PageTitleFormat,
            BaseUrl = settings.BaseUrl,
            TimeZoneId = settings.TimeZoneId,
            Calendar = settings.Calendar,
            PageSize = settings.PageSize,
            MaxPageSize = settings.MaxPageSize,
            MaxPagedCount = settings.MaxPagedCount,
        };

        public SiteSettingsUpdate ToUpdate() => new(
            SiteName,
            PageTitleFormat,
            BaseUrl,
            TimeZoneId,
            Calendar,
            PageSize,
            MaxPageSize,
            MaxPagedCount);
    }
}
