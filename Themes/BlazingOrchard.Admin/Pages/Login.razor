@page "/login"
@using BlazingOrchard.Admin.DisplayManagement
@using BlazingOrchard.Admin.Options
@using Radzen
@using Radzen.Blazor
@inject DisplayManager DisplayManager
@inject BlazingRoutingOptions Routing
@inject NavigationManager Navigation

<RadzenStack Gap="1rem" Style="padding: 2rem;">
    <RadzenText TextStyle="TextStyle.H3" Text="Blazing" />

    @if (DisplayManager.IsAuthenticated)
    {
        <RadzenText Text="@($"Signed in as {DisplayManager.User.UserName}")" />
        <RadzenButton Text="Logout" Click="LogoutAsync" Disabled="@DisplayManager.IsBusy" />
    }
    else
    {
        <RadzenTemplateForm TItem="LoginForm" Data="@_login" Submit="@((LoginForm form) => LoginAsync(form))">
            <RadzenStack Gap="0.75rem" Style="max-width: 22rem;">
                <RadzenTextBox Name="UserName" @bind-Value="_login.UserName" Placeholder="Username or email" />
                <RadzenPassword Name="Password" @bind-Value="_login.Password" Placeholder="Password" />
                <RadzenCheckBox @bind-Value="_login.RememberMe" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="Login" Disabled="@DisplayManager.IsBusy" />
                @if (DisplayManager.ErrorMessage is not null)
                {
                    <RadzenText TextStyle="TextStyle.Caption" Text="@DisplayManager.ErrorMessage" />
                }
            </RadzenStack>
        </RadzenTemplateForm>
    }
</RadzenStack>

@code {
    private LoginForm _login = new();

    protected override async Task OnInitializedAsync()
    {
        await DisplayManager.EnsureInitializedAsync();
        if (DisplayManager.IsAuthenticated)
        {
            Navigation.NavigateTo(Routing.AdminPath);
        }
    }

    private async Task LoginAsync(LoginForm form)
    {
        if (await DisplayManager.LoginAsync(form.UserName, form.Password, form.RememberMe))
        {
            Navigation.NavigateTo(Routing.AdminPath);
        }
    }

    private async Task LogoutAsync()
    {
        await DisplayManager.LogoutAsync();
        Navigation.NavigateTo(Routing.LoginPath);
    }

    private sealed class LoginForm
    {
        public string UserName { get; set; } = "";
        public string Password { get; set; } = "";
        public bool RememberMe { get; set; }
    }
}
